#!/bin/sh
set -eu

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname "$0")" && pwd)"
APP_CONTENTS_DIR="$(CDPATH= cd -- "$SCRIPT_DIR/.." && pwd)"
RES_DIR="$APP_CONTENTS_DIR/Resources"
LOG_DIR="${HOME}/Library/Logs/LineDrawing"
LOG_FILE="$LOG_DIR/launcher.log"

mkdir -p "$LOG_DIR" 2>/dev/null || true
if ! touch "$LOG_FILE" 2>/dev/null; then
    LOG_FILE="${TMPDIR:-/tmp}/line-drawing-launcher.log"
    touch "$LOG_FILE" 2>/dev/null || true
fi

export VK_RENDERER_SHADER_ROOT="${VK_RENDERER_SHADER_ROOT:-$RES_DIR}"
export SHAPE_ASSET_DIR="${SHAPE_ASSET_DIR:-$RES_DIR/export}"
export LINE_DRAWING3D_USE_SHARED_THEME="${LINE_DRAWING3D_USE_SHARED_THEME:-1}"
export LINE_DRAWING3D_USE_SHARED_THEME_FONT="${LINE_DRAWING3D_USE_SHARED_THEME_FONT:-1}"
export LINE_DRAWING3D_USE_SHARED_FONT="${LINE_DRAWING3D_USE_SHARED_FONT:-1}"
export LINE_DRAWING3D_FONT_PRESET="${LINE_DRAWING3D_FONT_PRESET:-daw_default}"

if [ "${1:-}" = "--print-config" ]; then
    echo "APP_CONTENTS_DIR=$APP_CONTENTS_DIR"
    echo "RES_DIR=$RES_DIR"
    echo "LOG_FILE=$LOG_FILE"
    echo "VK_RENDERER_SHADER_ROOT=$VK_RENDERER_SHADER_ROOT"
    echo "SHAPE_ASSET_DIR=$SHAPE_ASSET_DIR"
    echo "LINE_DRAWING3D_USE_SHARED_THEME=$LINE_DRAWING3D_USE_SHARED_THEME"
    echo "LINE_DRAWING3D_USE_SHARED_THEME_FONT=$LINE_DRAWING3D_USE_SHARED_THEME_FONT"
    echo "LINE_DRAWING3D_USE_SHARED_FONT=$LINE_DRAWING3D_USE_SHARED_FONT"
    echo "LINE_DRAWING3D_FONT_PRESET=$LINE_DRAWING3D_FONT_PRESET"
    exit 0
fi

if [ "${1:-}" = "--self-test" ]; then
    [ -x "$SCRIPT_DIR/line-drawing-bin" ] || { echo "missing: line-drawing-bin" >&2; exit 1; }
    [ -f "$APP_CONTENTS_DIR/Info.plist" ] || { echo "missing: Info.plist" >&2; exit 1; }
    [ -f "$RES_DIR/config/layout_config.json" ] || { echo "missing: config/layout_config.json" >&2; exit 1; }
    [ -f "$RES_DIR/include/fonts/Lato/Lato-Regular.ttf" ] || { echo "missing: include/fonts/Lato/Lato-Regular.ttf" >&2; exit 1; }
    [ -f "$RES_DIR/shared/assets/fonts/Montserrat-Regular.ttf" ] || { echo "missing: shared/assets/fonts/Montserrat-Regular.ttf" >&2; exit 1; }
    [ -d "$RES_DIR/data/runtime" ] || { echo "missing: data/runtime" >&2; exit 1; }
    [ -d "$RES_DIR/data/snapshots" ] || { echo "missing: data/snapshots" >&2; exit 1; }
    [ -d "$RES_DIR/export" ] || { echo "missing: export" >&2; exit 1; }
    [ -f "$RES_DIR/vk_renderer/shaders/textured.vert.spv" ] || { echo "missing: bundled vk shader" >&2; exit 1; }
    [ -f "$RES_DIR/shaders/textured.vert.spv" ] || { echo "missing: bundled runtime shader" >&2; exit 1; }
    echo "self-test: ok"
    echo "LOG_FILE=$LOG_FILE"
    echo "VK_RENDERER_SHADER_ROOT=$VK_RENDERER_SHADER_ROOT"
    echo "SHAPE_ASSET_DIR=$SHAPE_ASSET_DIR"
    echo "LINE_DRAWING3D_FONT_PRESET=$LINE_DRAWING3D_FONT_PRESET"
    exit 0
fi

cd "$RES_DIR"
printf '%s launch begin pid=%s cwd=%s shader_root=%s shape_asset_dir=%s args=%s\n' "$(date '+%Y-%m-%d %H:%M:%S')" "$$" "$RES_DIR" "$VK_RENDERER_SHADER_ROOT" "$SHAPE_ASSET_DIR" "$*" >>"$LOG_FILE" 2>/dev/null || true
exec "$SCRIPT_DIR/line-drawing-bin" "$@" >>"$LOG_FILE" 2>&1
